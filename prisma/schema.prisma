generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppUser {
  callsign         String   @id
  passwordHash     String
  isAdmin          Boolean  @default(false)
  activeSessionId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("app_users")
}

model SiteConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_config")
}

model Contest {
  slug      String   @id
  name      String
  ruleset   String   @default("field-day")
  settings  Json     @default("{}")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]

  @@map("contests")
}

model Contact {
  id               BigInt    @id
  timestamp        DateTime  @default(now())
  contestSlug      String    @default("field-day")
  callsign         String
  frequency        String?
  mode             String?
  classSent        String?
  locationReceived String?
  callSignArea     String?
  name             String?
  notes            String?
  rstSent          String?
  rstReceived      String?
  deleted          String    @default("N")
  createdBy        String?
  lastEditedBy     String?
  deletedBy        String?
  deletedAt        DateTime?
  restoredBy       String?
  restoredAt       DateTime?
  lastEditedAt     DateTime?

  history ContactHistory[]
  contest Contest      @relation(fields: [contestSlug], references: [slug], onDelete: Restrict)

  @@index([contestSlug])
  @@index([contestSlug, deleted])
  @@map("contacts")
}

model ContactHistory {
  id        String   @id @default(cuid())
  contactId BigInt
  action    String
  oldData   Json?
  newData   Json?
  operator  String?
  timestamp DateTime @default(now())
  changeId  String?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_history")
}

model ActiveOperator {
  callsign          String    @id
  name              String?
  frequency         String?
  mode              String?
  duplicateUser     String    @default("N")
  timestamp         DateTime  @default(now())
  bandModeTimestamp DateTime?

  @@map("active_operators")
}

model CallsignLookup {
  callsign  String   @id
  name      String?
  grid      String?
  city      String?
  state     String?
  country   String?
  timestamp DateTime @default(now())

  @@map("callsign_lookups")
}

model OneByOneReservation {
  id            Int      @id
  callsign      String
  coordinator   String?
  eventName     String?  @map("event_name")
  requestor     String?
  requestorCall String?  @map("requestor_call")
  requestorAddr String?  @map("requestor_addr")
  startDate     DateTime @map("start_date") @db.Date
  endDate       DateTime @map("end_date") @db.Date
  licenseName   String?  @map("license_name")
  grid          String?
  city          String?
  state         String?
  country       String?
  cachedAt      DateTime @default(now()) @map("cached_at")

  @@index([callsign])
  @@index([startDate, endDate])
  @@map("one_by_one_reservations")
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("sessions")
}
