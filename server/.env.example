# PostgreSQL
DATABASE_URL=postgresql://hamlog:hamlog@localhost:5432/hamlog

# Session signing secret (generate a long random string for production)
SESSION_SECRET=change-me-to-a-long-random-string

# Server port (App Runner/ECS sets PORT automatically)
PORT=3002

# Public URL of the deployed app (for CORS in production)
APP_URL=https://your-app.example.com

# Node environment
NODE_ENV=development
