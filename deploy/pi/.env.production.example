# Production environment for Docker Compose on Raspberry Pi
# Copy to .env.production and fill in (setup.sh generates this automatically)

POSTGRES_USER=hamlog
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hamlog

DATABASE_URL=postgresql://hamlog:change-me@db:5432/hamlog
SESSION_SECRET=change-me
NODE_ENV=production
PORT=3002

# Set to your Pi's LAN URL, e.g. http://192.168.1.50:3002
APP_URL=
