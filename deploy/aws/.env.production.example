# Production environment for docker compose on EC2
# Copy to .env.production and fill in (launch.sh generates this automatically)

POSTGRES_USER=hamlog
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hamlog

DATABASE_URL=postgresql://hamlog:change-me@db:5432/hamlog
SESSION_SECRET=change-me
NODE_ENV=production
PORT=3002

# Set after first deploy for CORS (http://YOUR_EC2_IP:3002 or https://your-domain.example.com)
APP_URL=
# Set to true when APP_URL uses https://
COOKIE_SECURE=false
